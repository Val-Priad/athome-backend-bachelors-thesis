<mjml>
  <mj-head>
    <mj-title>New estate contact request</mj-title>
    <mj-preview>Someone sent a message about your estate on AtHome</mj-preview>

    <mj-attributes>
      <mj-all font-family="Arial, sans-serif" />
      <mj-text font-size="15px" color="#444444" line-height="1.5" />
      <mj-button
        background-color="#ff3b3b"
        color="#ffffff"
        border-radius="8px"
        font-weight="bold"
      />
    </mj-attributes>
  </mj-head>

  <mj-body background-color="#f5f5f5">
    <mj-section padding="24px 0">
      <mj-column>
        <mj-text
          align="center"
          font-size="24px"
          font-weight="bold"
          color="#222222"
        >
          AtHome
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#ffffff" border-radius="12px" padding="32px">
      <mj-column>
        <mj-text
          font-size="22px"
          font-weight="bold"
          color="#222222"
          padding-bottom="8px"
        >
          New message about your estate
        </mj-text>

        <mj-text>
          Someone sent a message from the estate page on AtHome.
        </mj-text>

        <mj-divider border-color="#eeeeee" padding="20px 0" />

        <mj-text font-size="17px" font-weight="bold" color="#222222">
          Estate
        </mj-text>

        <mj-text>
          <strong>Title:</strong> {{ estate_title }}<br />
          <strong>Address:</strong> {{ estate_address }}
        </mj-text>

        <mj-button href="{{ estate_url }}" padding-top="12px">
          Open estate page
        </mj-button>

        <mj-text font-size="13px" color="#777777">
          Or open this link:<br />
          <a href="{{ estate_url }}" style="color: #ff3b3b">{{ estate_url }}</a>
        </mj-text>

        <mj-divider border-color="#eeeeee" padding="20px 0" />

        <mj-text font-size="17px" font-weight="bold" color="#222222">
          Sender
        </mj-text>

        <mj-text>
          <strong>Name:</strong> {{ sender_name }}<br />
          <strong>Email:</strong> {{ sender_email }}<br />
          <strong>Phone:</strong> {{ sender_phone }}
        </mj-text>

        <mj-text font-size="17px" font-weight="bold" color="#222222">
          Message
        </mj-text>

        <mj-text background-color="#f7f7f7" padding="16px">
          {{ message }}
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section padding="20px 0">
      <mj-column>
        <mj-text align="center" font-size="13px" color="#999999">
          This email was sent automatically by AtHome.
        </mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
